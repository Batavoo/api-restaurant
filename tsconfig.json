{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2023"],
    "outDir": "dist",
    "rootDir": "./",

    "paths": {
      "@/*": ["./src/*"]
    },

    "outDir": "./dist",
    // "module": "node16",
    "module": "node20",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
